APP_ENV=development
PORT=8080

DATABASE_URL=postgres://invoice_user:password@postgres:5432/invoice_db?sslmode=disable

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=invoices

# must match INGESTION_INTERNAL_TOKEN in api-gateway — min 32 chars
INTERNAL_TOKEN=your-internal-token-min-32-characters-long
